# ─── Tavus (server-side only — never bundled into the browser) ───────────
#
# REQUIRED. Your Tavus API key.
# Get one at: https://platform.tavus.io/api-keys
TAVUS_API_KEY=

# NOTE: persona_id and replica_id are NOT set here. They live in
# config/presets.config.json (the single source of truth). Paste an existing
# persona's ID there, or run `npm run init` to copy a reference persona into
# your Tavus account — it writes the persona_id back into
# config/presets.config.json automatically.
